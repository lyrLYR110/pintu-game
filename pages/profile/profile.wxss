/* profile.wxss — 个人中心样式 */

.container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 头部 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.avatar-area {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}

.btn-login {
  padding: 16rpx 50rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 30rpx;
  font-size: 28rpx;
}

.login-status {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

/* 区块 */
.section {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 15rpx rgba(0,0,0,0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.btn-upload {
  padding: 10rpx 30rpx;
  background: #667eea;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  font-size: 24rpx;
}

/* 收藏图片网格 */
.favorite-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.favorite-item {
  width: calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.favorite-img {
  width: 100%;
  height: 160rpx;
  border-radius: 12rpx;
}

.favorite-name {
  font-size: 22rpx;
  color: #666;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 40rpx;
}

/* 记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.record-item {
  display: flex;
  gap: 20rpx;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
}

.record-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-difficulty {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.record-time {
  font-size: 24rpx;
  color: #667eea;
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
  margin-top: 20rpx;
}

.brand-logo {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 20rpx;
}

.brand-slogan {
  font-size: 24rpx;
  color: #999;
}
