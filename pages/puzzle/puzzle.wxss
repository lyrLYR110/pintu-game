/* puzzle.wxss — 拼图对战页样式 */

.container {
  min-height: 100vh;
  background: #1a1a2e;
  color: #fff;
  display: flex;
  flex-direction: column;
}

/* 游戏头部 */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(255,255,255,0.05);
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.timer-section {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.timer-icon {
  font-size: 36rpx;
}

.timer-text {
  font-size: 40rpx;
  font-weight: bold;
  font-variant-numeric: tabular-nums;
  color: #ffd700;
}

.round-info {
  flex: 1;
  text-align: center;
}

.round-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

.game-actions {
  display: flex;
  gap: 15rpx;
}

.btn {
  padding: 14rpx 30rpx;
  background: #667eea;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.btn-sm {
  padding: 10rpx 24rpx;
  font-size: 22rpx;
}

.btn-secondary {
  background: rgba(255,255,255,0.15);
}

/* 记忆覆盖层 */
.memory-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.9);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.memory-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.memory-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
}

.memory-image {
  width: 500rpx;
  height: 500rpx;
  border-radius: 20rpx;
  border: 4rpx solid rgba(255,255,255,0.2);
}

.memory-countdown {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.1); }
}

/* 旋转控制 */
.rotate-controls {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.08);
}

.rotate-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #667eea;
  color: #fff;
  font-size: 36rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 拼图板 */
.puzzle-board-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.puzzle-board {
  position: relative;
  border: 3rpx solid rgba(255,255,255,0.2);
  border-radius: 10rpx;
  overflow: hidden;
}

.puzzle-piece {
  position: absolute;
  box-sizing: border-box;
  border: 1rpx solid rgba(255,255,255,0.3);
  cursor: pointer;
  transition: left 0.15s ease, top 0.15s ease, transform 0.15s ease;
}

.puzzle-piece.piece-selected {
  border: 3rpx solid #ffd700;
  box-shadow: 0 0 20rpx rgba(255,215,0,0.6);
  z-index: 10;
}

.puzzle-piece.piece-correct {
  border: 1rpx solid rgba(0,255,0,0.5);
  opacity: 0.8;
}

.piece-check {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  background: #4caf50;
  color: #fff;
  font-size: 20rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 操作信息 */
.game-info {
  padding: 20rpx 30rpx;
  text-align: center;
  background: rgba(255,255,255,0.05);
}

.info-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-bottom: 10rpx;
}

.correct-count {
  font-size: 28rpx;
  color: #4caf50;
  font-weight: bold;
}

/* 弹窗通用 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.85);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #1e1e3a;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  width: 85%;
  max-width: 600rpx;
  text-align: center;
}

/* 胜利弹窗 */
.win-modal {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.win-emoji {
  font-size: 80rpx;
}

.win-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffd700;
}

.win-time {
  font-size: 32rpx;
  color: rgba(255,255,255,0.8);
}

.win-stars {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin: 10rpx 0;
}

.star {
  font-size: 40rpx;
}

.star-on {
  color: #ffd700;
}

.win-comment {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

.win-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 20rpx;
}

/* 轮次结果弹窗 */
.round-result-modal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.result-emoji {
  font-size: 60rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #4caf50;
}

.result-wait {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  animation: pulse 2s ease-in-out infinite;
}

/* 最终排名弹窗 */
.final-modal {
  max-height: 80vh;
  overflow-y: auto;
}

.final-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 30rpx;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 15rpx;
}

.rank-badge {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.rank-1 { background: linear-gradient(135deg, #ffd700, #ff8c00); }
.rank-2 { background: linear-gradient(135deg, #c0c0c0, #808080); }
.rank-3 { background: linear-gradient(135deg, #cd7f32, #8b4513); }

.rank-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.rank-name {
  font-size: 28rpx;
  font-weight: bold;
}

.rank-stats {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.final-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}
